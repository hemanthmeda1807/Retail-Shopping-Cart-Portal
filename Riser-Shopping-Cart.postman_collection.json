{
  "info": {
    "name": "Riser Shopping Cart API",
    "description": "Complete API collection for the Riser retail portal. Demonstrates JWT auth, RBAC, API key authentication, error handling, and all CRUD operations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "riser-shopping-cart-v2"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "apiKey", "value": "your_api_key_here", "type": "string" },
    { "key": "userToken", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "categoryId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "UC-101 Sign Up (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Response is success', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('Token returned', () => pm.expect(pm.response.json().data.token).to.be.a('string'));",
                  "pm.test('User role is user', () => pm.expect(pm.response.json().data.user.role).to.equal('user'));",
                  "pm.collectionVariables.set('userToken', pm.response.json().data?.token || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Customer\",\n  \"email\": \"customer@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "UC-101 Sign Up - 400 Duplicate Email",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Error code is EMAIL_TAKEN', () => pm.expect(pm.response.json().error.code).to.equal('EMAIL_TAKEN'));",
                  "pm.test('Success is false', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/signup",
